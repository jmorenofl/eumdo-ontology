    <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/foaf#hasStatus">
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/foaf#CorrectiveAction(FCSA)"/>
        <rdfs:range rdf:resource="http://www.owl-ontologies.com/foaf#FSCAStatus"/>
        <rdfs:label>hasStatus</rdfs:label>
    </owl:ObjectProperty>
    


