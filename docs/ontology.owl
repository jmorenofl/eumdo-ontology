    </owl:ObjectProperty>
    


    <!-- http://www.owl-ontologies.com/foaf#regulatedBy -->


    <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/foaf#regulatedBy">
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/foaf#Device"/>
        <rdfs:range rdf:resource="http://www.owl-ontologies.com/foaf#RegulatoryFramework"/>
