    <!-- http://www.owl-ontologies.com/foaf#hasSeverity -->


    <owl:ObjectProperty rdf:about="http://www.owl-ontologies.com/foaf#hasSeverity">
        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/foaf#Risk"/>
        <rdfs:range rdf:resource="http://www.owl-ontologies.com/foaf#Severity"/>
        <rdfs:label>hasSeverity</rdfs:label>
    </owl:ObjectProperty>
    


