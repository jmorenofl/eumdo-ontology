    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.owl-ontologies.com/foaf#ActiveDevice -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/foaf#ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/foaf#Device"/>
        <rdfs:comment xml:lang="en">Device whose operation depends on a source of electrical energy or any source of power other than that generated by the human body or gravity</rdfs:comment>
        <rdfs:label xml:lang="en">ActiveDevice</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/foaf#ActiveImplant -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/foaf#ActiveImplant">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/foaf#ActiveDevice"/>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/foaf#ImplantableDevice"/>
        <rdfs:label>ActiveImplant</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/foaf#ClassA -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/foaf#ClassA">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/foaf#IVDRRiskClass"/>
        <rdfs:comment xml:lang="en">Lowest IVDR risk</rdfs:comment>
        <rdfs:label xml:lang="en">ClassA</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/foaf#ClassB -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/foaf#ClassB">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/foaf#IVDRRiskClass"/>
        <rdfs:comment xml:lang="en">Low-medium IVDR risk</rdfs:comment>
        <rdfs:label xml:lang="en">ClassB</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/foaf#ClassC -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/foaf#ClassC">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/foaf#IVDRRiskClass"/>
        <rdfs:comment xml:lang="en">Medium-high IVDR risk</rdfs:comment>
        <rdfs:label xml:lang="en">ClassC</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/foaf#ClassD -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/foaf#ClassD">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/foaf#IVDRRiskClass"/>
        <rdfs:comment xml:lang="en">Highest IVDR risk</rdfs:comment>
        <rdfs:label xml:lang="en">ClassD</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/foaf#ClassI -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/foaf#ClassI">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/foaf#MDRiskClass"/>
        <rdfs:comment xml:lang="en">Low risk</rdfs:comment>
        <rdfs:label xml:lang="en">ClassI</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/foaf#ClassIII -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/foaf#ClassIII">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/foaf#MDRiskClass"/>
        <rdfs:comment xml:lang="en">Highest risk</rdfs:comment>
        <rdfs:label xml:lang="en">ClassIII</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/foaf#ClassIIa -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/foaf#ClassIIa">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/foaf#MDRiskClass"/>
        <rdfs:comment xml:lang="en">Medium-low risk</rdfs:comment>
        <rdfs:label xml:lang="en">ClassIIa</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/foaf#ClassIIb -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/foaf#ClassIIb">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/foaf#MDRiskClass"/>
        <rdfs:comment xml:lang="en">Medium-high risk</rdfs:comment>
        <rdfs:label xml:lang="en">ClassIIb</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/foaf#Close -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/foaf#Close">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/foaf#FSCAStatus"/>
        <rdfs:comment xml:lang="en">Close</rdfs:comment>
        <rdfs:label xml:lang="en">Close</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/foaf#CompetentAuthority -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/foaf#CompetentAuthority">
        <rdfs:label>CompetentAuthority</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/foaf#ContaminationRisk -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/foaf#ContaminationRisk">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/foaf#Risk"/>
        <rdfs:comment xml:lang="en">Reagent contamination</rdfs:comment>
        <rdfs:label xml:lang="en">Contamination Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/foaf#Country -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/foaf#Country">
        <rdfs:comment xml:lang="en">Geopolitical country, linked to the EU Named Authority List</rdfs:comment>
        <rdfs:label xml:lang="en">Country</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/foaf#Critical -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/foaf#Critical">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/foaf#Severity"/>
        <rdfs:comment xml:lang="en">Critical</rdfs:comment>
        <rdfs:label xml:lang="en">Critical</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/foaf#Device -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/foaf#Device">
        <rdfs:comment xml:lang="en">A medical device or in-vitro diagnostic device as defined by Regulation (EU) 2017/745 or Regulation (EU) 2017/746.</rdfs:comment>
        <rdfs:label xml:lang="en">Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/foaf#DeviceFailure -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/foaf#DeviceFailure">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/foaf#Risk"/>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/foaf#RiskCategory"/>
        <rdfs:comment xml:lang="en">Device Failure</rdfs:comment>
        <rdfs:label xml:lang="en">DeviceFailure</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/foaf#DevicePerformance -->


    <owl:Class rdf:about="http://www.owl-ontologies.com/foaf#DevicePerformance">
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/foaf#Risk"/>
        <rdfs:subClassOf rdf:resource="http://www.owl-ontologies.com/foaf#RiskCategory"/>
        <rdfs:comment xml:lang="en">Device Performance</rdfs:comment>
        <rdfs:label xml:lang="en">DevicePerformance</rdfs:label>
    </owl:Class>
    


    <!-- http://www.owl-ontologies.com/foaf#DeviceSafety -->


