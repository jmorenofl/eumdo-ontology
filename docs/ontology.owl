        <rdfs:domain rdf:resource="http://www.owl-ontologies.com/foaf#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>isReusable</rdfs:label>
    </owl:DatatypeProperty>
    


